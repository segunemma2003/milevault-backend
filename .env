# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/milevault
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
UPLOAD_DIR=./uploads
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
ENVIRONMENT=development

# ── Cookie ────────────────────────────────────────────────────────────────────
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── AWS S3 (leave blank to use local fallback) ────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=milevault-uploads
S3_PRESIGNED_EXPIRY=3600
CDN_BASE_URL=

# ── Payment Gateways ──────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_key_here
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@milevault.com
ADMIN_SECRET=change-this-admin-bootstrap-secret

# ── Watermarking ──────────────────────────────────────────────────────────────
WATERMARK_TEXT=MileVault
