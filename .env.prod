# ── Core ──────────────────────────────────────────────────────────────────────
# RDS endpoint: postgresql://user:pass@your-rds.region.rds.amazonaws.com:5432/milevault
DATABASE_URL=postgresql://milevault:CHANGE_ME@your-rds-endpoint.rds.amazonaws.com:5432/milevault
SECRET_KEY=CHANGE_TO_64_RANDOM_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
UPLOAD_DIR=./uploads
CORS_ORIGINS=["https://your-cloudfront-domain.cloudfront.net","https://milevault.ng"]
ENVIRONMENT=production

# ── Cookie ────────────────────────────────────────────────────────────────────
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=milevault.ng

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://milevault.ng

# ── Redis (ElastiCache) ────────────────────────────────────────────────────────
# ElastiCache endpoint: rediss://your-cache.region.cache.amazonaws.com:6379
REDIS_URL=rediss://your-elasticache.cache.amazonaws.com:6379/0
CELERY_BROKER_URL=rediss://your-elasticache.cache.amazonaws.com:6379/1
CELERY_RESULT_BACKEND=rediss://your-elasticache.cache.amazonaws.com:6379/2

# ── AWS S3 (uploads bucket — different from frontend bucket) ──────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=milevault-uploads
S3_PRESIGNED_EXPIRY=3600
CDN_BASE_URL=

# ── Payment Gateways ──────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE-...
FLUTTERWAVE_WEBHOOK_SECRET=
